# Vorlage für lokale Umgebungsvariablen.
# Datei in ".env" umbenennen und Werte eintragen.
# .env wird via .gitignore aus dem Repository ausgeschlossen.

# === Groq Cloud-LLM ===
# Kostenfreier Schlüssel von https://console.groq.com → API Keys → Create API Key
# Wird primär in der Render-/Workshop-Demo genutzt.
# Wenn nicht gesetzt, fällt der Code automatisch auf Ollama (lokal) zurück.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Lokales Ollama (optional) ===
# Wird nur genutzt, wenn KEIN GROQ_API_KEY gesetzt ist.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# === Lokale Spracherkennung (faster-whisper) ===
# Modellgrößen: tiny | base | small | medium | large
# medium = beste Erkennung, ca. 1,5 GB RAM
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# === Flask-Debug ===
# Auf "1" setzen, um den Werkzeug-Debugger zu aktivieren.
# WARNUNG: Niemals in Produktion einschalten – RCE-Schwachstelle!
FLASK_DEBUG=0
